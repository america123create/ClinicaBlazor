@page "/dashboard"
@rendermode InteractiveServer

@using ClinicaBlazor.Services
@inject SesionService SesionService
@inject NavigationManager Navigation

<PageTitle>Dashboard</PageTitle>

@if (!cargado)
{
    <div class="dashboard-v3">
        <div class="card-v3">Cargando...</div>
    </div>
}
else if (!haySesion)
{
    <div class="dashboard-v3">
        <div class="card-v3">Redirigiendo...</div>
    </div>
}
else
{
    <div class="dashboard-pink">

        <!-- HEADER -->
        <div class="dashboard-header-pink">

            <div>
                <h1>🏥 ClinicaBlazor</h1>
                <p>Panel de control del sistema</p>
            </div>

            <div class="user-chip-pink">
                <div class="avatar-pink">
                    @nombreUsuario.Substring(0, 1)
                </div>

                <div>
                    <strong>@nombreUsuario</strong><br />
                    <small>@perfilUsuario</small>
                </div>
            </div>

        </div>

        <Breadcrumbs Items="breadcrumbItems" />

        <!-- GRID -->
        <div class="dashboard-grid-pink">

            <!-- PERFIL -->
            <div class="card-pink">

                <h3>👤 Perfil de Usuario</h3>

                <div class="row">
                    <span>Nombre:</span>
                    <strong>@nombreUsuario</strong>
                </div>

                <div class="row">
                    <span>Correo:</span>
                    <strong>@correoUsuario</strong>
                </div>

                <div class="row">
                    <span>Perfil:</span>
                    <span class="badge-pink">@perfilUsuario</span>
                </div>

                <div class="status-pink">● Activo</div>

            </div>

            <!-- BIENVENIDA -->
            <div class="card-pink welcome-pink">

                <div class="tag-pink">Panel de Control</div>

                <h2>Bienvenido, @nombreUsuario</h2>

                <p>
                    Sistema clínico de gestión con seguridad, usuarios y permisos centralizados.
                </p>

                <div class="chips-pink">
                    <span>🔐 Seguridad</span>
                    <span>👥 Usuarios</span>
                    <span>⚙️ Permisos</span>
                </div>

            </div>

        </div>

    </div>
}

@code {
    private bool cargado;
    private bool haySesion;

    private string nombreUsuario = "Administrador";
    private string perfilUsuario = "Admin";
    private string correoUsuario = "admin@sistema.com";

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Texto = "Inicio", Url = "/dashboard" }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        haySesion = await SesionService.HaySesionAsync();

        if (!haySesion)
        {
            cargado = true;
            StateHasChanged();
            Navigation.NavigateTo("/login", true);
            return;
        }

        nombreUsuario = await SesionService.ObtenerNombreAsync() ?? "Administrador";
        perfilUsuario = await SesionService.ObtenerPerfilAsync() ?? "Admin";

        cargado = true;
        StateHasChanged();
    }

}

