@page "/dashboard"
@rendermode InteractiveServer
@using ClinicaBlazor.Services
@inject SesionService SesionService
@inject NavigationManager Navigation

<PageTitle>Dashboard</PageTitle>

@if (!cargado)
{
    <p>Cargando...</p>
}
else if (!haySesion)
{
    <p>Redirigiendo...</p>
}
else
{
    <Breadcrumbs Items="breadcrumbItems" />

    <section class="dashboard-shell">
        <article class="profile-card-v2">
            <div class="profile-card-v2__header">
                <div class="profile-avatar-v2"></div>

                <div>
                    <h2>Perfil de Usuario</h2>
                    <p>Datos de acceso y credenciales</p>
                </div>
            </div>

            <div class="profile-card-v2__body">
                <div class="profile-row-v2">
                    <span class="profile-label-v2">Nombre completo</span>
                    <span class="profile-value-v2">@nombreUsuario</span>
                </div>

                <div class="profile-row-v2">
                    <span class="profile-label-v2">Correo electrónico</span>
                    <span class="profile-value-v2">@correoUsuario</span>
                </div>

                <div class="profile-row-v2">
                    <span class="profile-label-v2">Perfil asignado</span>
                    <span class="profile-value-v2">@perfilUsuario</span>
                </div>

                <div class="profile-row-v2">
                    <span class="profile-label-v2">Estado de la cuenta</span>
                    <span class="status-pill active">• Activo</span>
                </div>
            </div>

            <div class="profile-card-v2__footer">
                Acceso autorizado al sistema corporativo
            </div>
        </article>

        <article class="welcome-card-v2">
            <div class="welcome-badge-v2">Panel de Control</div>

            <h1>
                Bienvenido, <span>@nombreUsuario</span>
            </h1>

            <p>
                Le damos la bienvenida al sistema de gestión corporativa. Desde este panel
                central podrá administrar y supervisar los módulos disponibles con seguridad
                y eficiencia.
            </p>

            <div class="welcome-tags-v2">
                <div class="welcome-tag-v2">Acceso seguro</div>
                <div class="welcome-tag-v2">Protección de datos</div>
                <div class="welcome-tag-v2">Permisos por perfil</div>
            </div>
        </article>
    </section>
}

@code {
    private bool cargado;
    private bool haySesion;

    private string nombreUsuario = "Administrador";
    private string perfilUsuario = "Admin";
    private string correoUsuario = "admin@sistema.com";

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Texto = "Inicio", Url = "/dashboard" }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        haySesion = await SesionService.HaySesionAsync();

        if (!haySesion)
        {
            cargado = true;
            StateHasChanged();
            Navigation.NavigateTo("/login", true);
            return;
        }

        nombreUsuario = await SesionService.ObtenerNombreAsync() ?? "Administrador";
        perfilUsuario = await SesionService.ObtenerPerfilAsync() ?? "Admin";

        cargado = true;
        StateHasChanged();
    }
}