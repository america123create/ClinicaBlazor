@page "/seguridad/perfil"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using ClinicaBlazor.Services
@using ClinicaBlazor.Models
@inject PerfilService PerfilService
@inject PermisoPerfilService PermisoPerfilService
@inject SesionService SesionService
@inject NavigationManager Navigation

<PageTitle>Perfiles</PageTitle>

@if (!cargado)
{
    <p>Cargando...</p>
}
else if (!haySesion)
{
    <p>Redirigiendo...</p>
}
else
{
    <Breadcrumbs Items="breadcrumbItems" />

    <section class="module-header">
        <h1>Perfiles</h1>
        <p>Gestión de perfiles del sistema</p>
    </section>

    <!-- BOTÓN + NUEVO -->
    <div class="actions-bar">
        @if (puedeAgregar)
        {
            <button class="btn btn-primary" @onclick="MostrarFormulario">
                + Nuevo perfil
            </button>
        }
    </div>

    <!-- FORMULARIO (SOLO SE MUESTRA SI ESTA ACTIVO) -->
    @if (mostrarFormulario)
    {
        <div class="modal-backdrop" @onclick="CerrarFormulario">
            <div class="modal-container" @onclick:stopPropagation="true">

                <div class="modal-header">
                    <h3>@(nuevoPerfil.Id == 0 ? "Nuevo Perfil" : "Editar Perfil")</h3>
                    <button class="close-btn" @onclick="CerrarFormulario">✖</button>
                </div>

                <EditForm Model="nuevoPerfil" OnValidSubmit="GuardarPerfil">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="modal-body">
                        <label>Nombre del perfil</label>
                        <InputText @bind-Value="nuevoPerfil.Nombre" class="form-control" />

                        <label style="margin-top:10px;">Configuración</label>
                        <label>
                            <InputCheckbox @bind-Value="nuevoPerfil.Administrador" />
                            Es administrador
                        </label>
                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">
                            Guardar
                        </button>

                        <button type="button" class="btn btn-secondary" @onclick="CerrarFormulario">
                            Cancelar
                        </button>
                    </div>
                </EditForm>

            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert alert-success">@mensaje</div>
    }

    <!-- DETALLE -->
    @if (mostrarDetalle && perfilDetalle != null)
    {
        <section class="detail-card">
            <h3>Detalle del perfil</h3>

            <div class="detail-info">
                <p><strong>ID:</strong> @perfilDetalle.Id</p>
                <p><strong>Nombre:</strong> @perfilDetalle.Nombre</p>
                <p><strong>Administrador:</strong> @(perfilDetalle.Administrador ? "Sí" : "No")</p>
            </div>

            <button class="btn btn-secondary" @onclick="CerrarDetalle">
                Cerrar detalle
            </button>
        </section>
    }

    <!-- TABLA -->
    <section class="module-table-card">
        <table class="table-pink">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Administrador</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var perfil in perfilesPaginados)
                {
                    <tr>
                        <td>@perfil.Nombre</td>
                        <td>
                            <span class="status-pill @(perfil.Administrador ? "active" : "inactive")">
                                • @(perfil.Administrador ? "Sí" : "No")
                            </span>
                        </td>
                        <td>
                            <div class="action-group">

                                @if (puedeDetalle)
                                {
                                    <button class="btn-action detail" @onclick="() => VerDetalle(perfil)">
                                        Detalle
                                    </button>
                                }

                                @if (puedeEditar)
                                {
                                    <button class="btn-action edit" @onclick="() => EditarPerfil(perfil)">
                                        Editar
                                    </button>
                                }

                                @if (puedeEliminar)
                                {
                                    <button class="btn-action delete" @onclick="() => EliminarPerfil(perfil.Id)">
                                        Eliminar
                                    </button>
                                }

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <!-- PAGINACIÓN -->
    <section class="module-footer-card">
        <span>Página @paginaActual de @TotalPaginas</span>

        <div class="action-group">
            <button class="btn btn-secondary" @onclick="PaginaAnterior" disabled="@(paginaActual == 1)">
                &lt;
            </button>

            <button class="btn btn-secondary" @onclick="PaginaSiguiente" disabled="@(paginaActual == TotalPaginas)">
                &gt;
            </button>
        </div>
    </section>
}

@code {
    private bool cargado;
    private bool haySesion;
    private string? mensaje;

    private bool puedeAgregar;
    private bool puedeEditar;
    private bool puedeEliminar;
    private bool puedeConsultar;
    private bool puedeDetalle;

    private bool mostrarFormulario = false;
    private bool mostrarDetalle;

    private ClinicaBlazor.Models.Perfil? perfilDetalle;

    private int paginaActual = 1;
    private int filasPorPagina = 5;

    private ClinicaBlazor.Models.Perfil nuevoPerfil = new();
    private List<ClinicaBlazor.Models.Perfil> perfiles = new();

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Texto = "Inicio", Url = "/dashboard" },
        new BreadcrumbItem { Texto = "Seguridad" },
        new BreadcrumbItem { Texto = "Perfil" }
    };

    private int TotalPaginas =>
        perfiles.Count == 0 ? 1 : (int)Math.Ceiling((double)perfiles.Count / filasPorPagina);

    private List<ClinicaBlazor.Models.Perfil> perfilesPaginados =>
        perfiles.Skip((paginaActual - 1) * filasPorPagina).Take(filasPorPagina).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        haySesion = await SesionService.HaySesionAsync();

        if (!haySesion)
        {
            cargado = true;
            StateHasChanged();
            Navigation.NavigateTo("/login", true);
            return;
        }

        var perfilNombre = await SesionService.ObtenerPerfilAsync();

        if (!string.IsNullOrWhiteSpace(perfilNombre))
        {
            var perfilSesion = await PerfilService.ObtenerPorNombreAsync(perfilNombre);

            if (perfilSesion != null)
            {
                var permiso = await PermisoPerfilService
                    .ObtenerPermisoPorPerfilYRutaAsync(perfilSesion.Id, "/seguridad/perfil");

                if (permiso != null)
                {
                    puedeAgregar = permiso.Agregar;
                    puedeEditar = permiso.Editar;
                    puedeEliminar = permiso.Eliminar;
                    puedeConsultar = permiso.Consultar;
                    puedeDetalle = permiso.Detalle;
                }
            }
        }

        if (!puedeConsultar)
        {
            cargado = true;
            StateHasChanged();
            Navigation.NavigateTo("/dashboard", true);
            return;
        }

        await CargarPerfiles();
        cargado = true;
        StateHasChanged();
    }

    private async Task CargarPerfiles()
    {
        perfiles = await PerfilService.ObtenerTodosAsync();
    }

    private async Task GuardarPerfil()
    {
        mensaje = null;

        if (nuevoPerfil.Id == 0 && !puedeAgregar)
        {
            mensaje = "No tienes permiso para agregar.";
            return;
        }

        if (nuevoPerfil.Id != 0 && !puedeEditar)
        {
            mensaje = "No tienes permiso para editar.";
            return;
        }

        await PerfilService.GuardarAsync(nuevoPerfil);

        mensaje = nuevoPerfil.Id == 0
            ? "Perfil guardado correctamente."
            : "Perfil actualizado correctamente.";

        nuevoPerfil = new ClinicaBlazor.Models.Perfil();

        mostrarFormulario = false;

        await CargarPerfiles();
        ReiniciarPaginacionSiHaceFalta();
    }

    private void MostrarFormulario()
    {
        mensaje = null;
        nuevoPerfil = new ClinicaBlazor.Models.Perfil();
        mostrarFormulario = true;
    }

    private void CancelarEdicion()
    {
        mensaje = null;
        nuevoPerfil = new ClinicaBlazor.Models.Perfil();
        mostrarFormulario = false;
    }

    private void EditarPerfil(ClinicaBlazor.Models.Perfil perfil)
    {
        mensaje = null;
        mostrarDetalle = false;

        nuevoPerfil = new ClinicaBlazor.Models.Perfil
        {
            Id = perfil.Id,
            Nombre = perfil.Nombre,
            Administrador = perfil.Administrador
        };

        mostrarFormulario = true;
    }

    private async Task EliminarPerfil(int id)
    {
        mensaje = null;

        if (!puedeEliminar)
        {
            mensaje = "No tienes permiso para eliminar.";
            return;
        }

        await PerfilService.EliminarAsync(id);

        mensaje = "Perfil eliminado correctamente.";

        await CargarPerfiles();
        ReiniciarPaginacionSiHaceFalta();
    }

    private void VerDetalle(ClinicaBlazor.Models.Perfil perfil)
    {
        mensaje = null;

        if (!puedeDetalle)
        {
            mensaje = "No tienes permiso para ver detalle.";
            return;
        }

        perfilDetalle = perfil;
        mostrarDetalle = true;
    }

    private void CerrarDetalle()
    {
        mostrarDetalle = false;
        perfilDetalle = null;
    }

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
            paginaActual--;
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas)
            paginaActual++;
    }

    private void ReiniciarPaginacionSiHaceFalta()
    {
        if (paginaActual > TotalPaginas)
            paginaActual = TotalPaginas;
    }

    private void CerrarFormulario()
    {
        nuevoPerfil = new ClinicaBlazor.Models.Perfil();
        mostrarFormulario = false;
    }
}