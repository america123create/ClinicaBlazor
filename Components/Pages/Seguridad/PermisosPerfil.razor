@page "/seguridad/permisos-perfil"
@rendermode InteractiveServer
@using ClinicaBlazor.Models
@inject PermisoPerfilService PermisoPerfilService
@inject PerfilService PerfilService
@inject ModuloService ModuloService
@inject SesionService SesionService
@inject NavigationManager Navigation

<PageTitle>Permisos por Perfil</PageTitle>

@if (!cargado)
{
    <p>Cargando...</p>
}
else if (!haySesion)
{
    <p>Redirigiendo...</p>
}
else
{
    <section class="header-premium">
        <h1>🔐 Gestión de Permisos</h1>
        <p>Administra accesos por perfil</p>
    </section>

    <!-- FILTRO -->
    <section class="form-card">
        <div class="form-group">
            <label>Filtrar por perfil</label>

            <div style="display:flex; gap:10px;">
                <select class="form-control"
                        style="max-width:350px;"
                        @onchange="OnPerfilChange">
                    <option value="0">— Todos los perfiles —</option>

                    @foreach (var p in perfilesDisponibles)
                    {
                        <option value="@p.Id">@p.Nombre</option>
                    }
                </select>

                <button class="btn btn-secondary" @onclick="LimpiarFiltro">
                    ✖
                </button>
            </div>
        </div>
    </section>

    <!-- MENSAJE -->
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="toast-success">@mensaje</div>
    }

    <!-- TABLA -->
    <section class="module-table-card">
        <table class="module-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Módulo</th>
                    <th>Agregar</th>
                    <th>Editar</th>
                    <th>Consulta</th>
                    <th>Eliminar</th>
                    <th>Detalle</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (!permisosPaginados.Any())
                {
                    <tr>
                        <td colspan="8" style="text-align:center; padding:40px;">
                            ☝ Selecciona un perfil
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var permiso in permisosPaginados)
                    {
                        <tr>
                            <td>@permiso.Id</td>
                            <td>@permiso.Modulo?.Nombre</td>

                            <td>@Switch(permiso, nameof(permiso.Agregar), permiso.Agregar)</td>
                            <td>@Switch(permiso, nameof(permiso.Editar), permiso.Editar)</td>
                            <td>@Switch(permiso, nameof(permiso.Consultar), permiso.Consultar)</td>
                            <td>@Switch(permiso, nameof(permiso.Eliminar), permiso.Eliminar)</td>
                            <td>@Switch(permiso, nameof(permiso.Detalle), permiso.Detalle)</td>

                            <td>
                                <div class="action-group">

                                    <button class="btn btn-info btn-sm"
                                            @onclick="() => VerDetalle(permiso.Id)">
                                        Detalle
                                    </button>

                                    <button class="btn-action delete"
                                            @onclick="() => EliminarPermiso(permiso.Id)">
                                        🗑
                                    </button>

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </section>

    <!-- PAGINACIÓN -->
    <section class="module-footer-card">
        <span>Página @paginaActual de @TotalPaginas</span>

        <div class="action-group">
            <button class="btn btn-secondary"
                    @onclick="PaginaAnterior"
                    disabled="@(paginaActual == 1)">
                &lt;
            </button>

            <button class="btn btn-secondary"
                    @onclick="PaginaSiguiente"
                    disabled="@(paginaActual == TotalPaginas)">
                &gt;
            </button>
        </div>
    </section>
}

@code {
    private bool cargado;
    private bool haySesion;
    private string? mensaje;

    private int paginaActual = 1;
    private int filasPorPagina = 5;
    private int perfilSeleccionadoId = 0;

    private List<PermisoPerfil> permisos = new();
    private List<Perfil> perfilesDisponibles = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        haySesion = await SesionService.HaySesionAsync();

        if (!haySesion)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        perfilesDisponibles = await PerfilService.ObtenerTodosAsync();
        permisos = await PermisoPerfilService.ObtenerTodosAsync();

        cargado = true;
        StateHasChanged();
    }

    private List<PermisoPerfil> permisosFiltrados =>
        perfilSeleccionadoId == 0
            ? new()
            : permisos.Where(p => p.PerfilId == perfilSeleccionadoId).ToList();

    private List<PermisoPerfil> permisosPaginados =>
        permisosFiltrados
            .Skip((paginaActual - 1) * filasPorPagina)
            .Take(filasPorPagina)
            .ToList();

    private int TotalPaginas =>
        permisosFiltrados.Count == 0 ? 1 :
        (int)Math.Ceiling((double)permisosFiltrados.Count / filasPorPagina);

    private void OnPerfilChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            perfilSeleccionadoId = id;
            paginaActual = 1;
        }
    }

    private void LimpiarFiltro()
    {
        perfilSeleccionadoId = 0;
        paginaActual = 1;
    }

    private async Task TogglePermiso(PermisoPerfil permiso, string campo, bool valor)
    {
        switch (campo)
        {
            case nameof(permiso.Agregar): permiso.Agregar = valor; break;
            case nameof(permiso.Editar): permiso.Editar = valor; break;
            case nameof(permiso.Consultar): permiso.Consultar = valor; break;
            case nameof(permiso.Eliminar): permiso.Eliminar = valor; break;
            case nameof(permiso.Detalle): permiso.Detalle = valor; break;
        }

        await PermisoPerfilService.GuardarAsync(permiso);
        mensaje = "✔ Actualizado";
    }

    private RenderFragment Switch(PermisoPerfil permiso, string campo, bool valor) => builder =>
    {
        builder.OpenElement(0, "label");
        builder.AddAttribute(1, "class", "switch");

        builder.OpenElement(2, "input");
        builder.AddAttribute(3, "type", "checkbox");
        builder.AddAttribute(4, "checked", valor);
        builder.AddAttribute(5, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this,
            e => TogglePermiso(permiso, campo, (bool)e.Value)));
        builder.CloseElement();

        builder.OpenElement(6, "span");
        builder.AddAttribute(7, "class", "slider");
        builder.CloseElement();

        builder.CloseElement();
    };

    private void VerDetalle(int id)
    {
        Navigation.NavigateTo($"/seguridad/permisos/detalle/{id}");
    }

    private async Task EliminarPermiso(int id)
    {
        await PermisoPerfilService.EliminarAsync(id);
        permisos = await PermisoPerfilService.ObtenerTodosAsync();
    }
   
    private void PaginaAnterior()
    {
        if (paginaActual > 1) paginaActual--;
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas) paginaActual++;
    }

    private void Volver()
    {
        Navigation.NavigateTo("/seguridad/permisos-perfil", forceLoad: true);
    }
}