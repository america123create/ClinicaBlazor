@page "/seguridad/modulos"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using ClinicaBlazor.Services
@inject ModuloService ModuloService
@inject PerfilService PerfilService
@inject PermisoPerfilService PermisoPerfilService
@inject SesionService SesionService
@inject NavigationManager Navigation

<PageTitle>Módulos</PageTitle>

@if (!cargado)
{
    <p>Cargando...</p>
}
else if (!haySesion)
{
    <p>Redirigiendo...</p>
}
else
{
    <Breadcrumbs Items="breadcrumbItems" />

    <section class="module-header">
        <h1>Módulos</h1>
        <p>Gestión de módulos del sistema</p>
    </section>

    <section class="form-card">
        <EditForm Model="nuevoModulo" OnValidSubmit="GuardarModulo">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-grid">
                <div class="form-group">
                    <label>Nombre</label>
                    <InputText @bind-Value="nuevoModulo.Nombre" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Clave</label>
                    <InputText @bind-Value="nuevoModulo.Clave" class="form-control" />
                </div>

                <div class="form-group full-width">
                    <label>Ruta</label>
                    <InputText @bind-Value="nuevoModulo.Ruta" class="form-control" />
                </div>

                <div class="form-actions full-width">
                    @if ((nuevoModulo.Id == 0 && puedeAgregar) || (nuevoModulo.Id != 0 && puedeEditar))
                    {
                        <button type="submit" class="btn btn-primary module-add-btn">
                            @(nuevoModulo.Id == 0 ? "Guardar módulo" : "Actualizar módulo")
                        </button>
                    }

                    @if (nuevoModulo.Id != 0)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="CancelarEdicion">
                            Cancelar
                        </button>
                    }
                </div>
            </div>
        </EditForm>
    </section>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert alert-success">@mensaje</div>
    }

    @if (mostrarDetalle && moduloDetalle != null)
    {
        <section class="detail-card">
            <h3>Detalle del módulo</h3>

            <div class="detail-info">
                <p><strong>ID:</strong> @moduloDetalle.Id</p>
                <p><strong>Nombre:</strong> @moduloDetalle.Nombre</p>
                <p><strong>Clave:</strong> @moduloDetalle.Clave</p>
                <p><strong>Ruta:</strong> @moduloDetalle.Ruta</p>
            </div>

            <button class="btn btn-secondary" @onclick="CerrarDetalle">
                Cerrar detalle
            </button>
        </section>
    }

    <section class="module-table-card">
        <table class="module-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Clave</th>
                    <th>Ruta</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var modulo in modulosPaginados)
                {
                    <tr>
                        <td>@modulo.Nombre</td>
                        <td>@modulo.Clave</td>
                        <td>@modulo.Ruta</td>
                        <td>
                            <div class="action-group">
                                @if (puedeDetalle)
                                {
                                    <button class="btn-action detail" @onclick="() => VerDetalle(modulo)">
                                        Detalle
                                    </button>
                                }

                                @if (puedeEditar)
                                {
                                    <button class="btn-action edit" @onclick="() => EditarModulo(modulo)">
                                        Editar
                                    </button>
                                }

                                @if (puedeEliminar)
                                {
                                    <button class="btn-action delete" @onclick="() => EliminarModulo(modulo.Id)">
                                        Eliminar
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <section class="module-footer-card">
        <span>Página @paginaActual de @TotalPaginas</span>

        <div class="action-group">
            <button class="btn btn-secondary" @onclick="PaginaAnterior" disabled="@(paginaActual == 1)">
                &lt;
            </button>

            <button class="btn btn-secondary" @onclick="PaginaSiguiente" disabled="@(paginaActual == TotalPaginas)">
                &gt;
            </button>
        </div>
    </section>
}

@code {
    private bool cargado;
    private bool haySesion;
    private string? mensaje;

    private bool puedeAgregar;
    private bool puedeEditar;
    private bool puedeEliminar;
    private bool puedeConsultar;
    private bool puedeDetalle;

    private bool mostrarDetalle;
    private ClinicaBlazor.Models.Modulo? moduloDetalle;

    private int paginaActual = 1;
    private int filasPorPagina = 5;

    private ClinicaBlazor.Models.Modulo nuevoModulo = new();
    private List<ClinicaBlazor.Models.Modulo> modulos = new();

    private List<BreadcrumbItem> breadcrumbItems = new()
    {
        new BreadcrumbItem { Texto = "Inicio", Url = "/dashboard" },
        new BreadcrumbItem { Texto = "Seguridad" },
        new BreadcrumbItem { Texto = "Módulo" }
    };

    private int TotalPaginas =>
        modulos.Count == 0 ? 1 : (int)Math.Ceiling((double)modulos.Count / filasPorPagina);

    private List<ClinicaBlazor.Models.Modulo> modulosPaginados =>
        modulos.Skip((paginaActual - 1) * filasPorPagina).Take(filasPorPagina).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        haySesion = await SesionService.HaySesionAsync();

        if (!haySesion)
        {
            cargado = true;
            StateHasChanged();
            Navigation.NavigateTo("/login", true);
            return;
        }

        var perfilNombre = await SesionService.ObtenerPerfilAsync();

        if (!string.IsNullOrWhiteSpace(perfilNombre))
        {
            var perfilSesion = await PerfilService.ObtenerPorNombreAsync(perfilNombre);

            if (perfilSesion != null)
            {
                var permiso = await PermisoPerfilService.ObtenerPermisoPorPerfilYRutaAsync(perfilSesion.Id, "/seguridad/modulos");

                if (permiso != null)
                {
                    puedeAgregar = permiso.Agregar;
                    puedeEditar = permiso.Editar;
                    puedeEliminar = permiso.Eliminar;
                    puedeConsultar = permiso.Consultar;
                    puedeDetalle = permiso.Detalle;
                }
            }
        }

        if (!puedeConsultar)
        {
            cargado = true;
            StateHasChanged();
            Navigation.NavigateTo("/dashboard", true);
            return;
        }

        await CargarModulos();
        cargado = true;
        StateHasChanged();
    }

    private async Task CargarModulos()
    {
        modulos = await ModuloService.ObtenerTodosAsync();
    }

    private async Task GuardarModulo()
    {
        mensaje = null;

        if (nuevoModulo.Id == 0 && !puedeAgregar)
        {
            mensaje = "No tienes permiso para agregar.";
            return;
        }

        if (nuevoModulo.Id != 0 && !puedeEditar)
        {
            mensaje = "No tienes permiso para editar.";
            return;
        }

        await ModuloService.GuardarAsync(nuevoModulo);

        mensaje = nuevoModulo.Id == 0
            ? "Módulo guardado correctamente."
            : "Módulo actualizado correctamente.";

        nuevoModulo = new ClinicaBlazor.Models.Modulo();
        await CargarModulos();
        ReiniciarPaginacionSiHaceFalta();
    }

    private void EditarModulo(ClinicaBlazor.Models.Modulo modulo)
    {
        mensaje = null;
        mostrarDetalle = false;
        moduloDetalle = null;

        nuevoModulo = new ClinicaBlazor.Models.Modulo
        {
            Id = modulo.Id,
            Nombre = modulo.Nombre,
            Clave = modulo.Clave,
            Ruta = modulo.Ruta
        };
    }

    private void CancelarEdicion()
    {
        mensaje = null;
        nuevoModulo = new ClinicaBlazor.Models.Modulo();
    }

    private async Task EliminarModulo(int id)
    {
        mensaje = null;

        if (!puedeEliminar)
        {
            mensaje = "No tienes permiso para eliminar.";
            return;
        }

        await ModuloService.EliminarAsync(id);
        mensaje = "Módulo eliminado correctamente.";

        if (nuevoModulo.Id == id)
            nuevoModulo = new ClinicaBlazor.Models.Modulo();

        if (moduloDetalle?.Id == id)
        {
            moduloDetalle = null;
            mostrarDetalle = false;
        }

        await CargarModulos();
        ReiniciarPaginacionSiHaceFalta();
    }

    private void VerDetalle(ClinicaBlazor.Models.Modulo modulo)
    {
        mensaje = null;

        if (!puedeDetalle)
        {
            mensaje = "No tienes permiso para ver detalle.";
            return;
        }

        moduloDetalle = new ClinicaBlazor.Models.Modulo
        {
            Id = modulo.Id,
            Nombre = modulo.Nombre,
            Clave = modulo.Clave,
            Ruta = modulo.Ruta
        };

        mostrarDetalle = true;
    }

    private void CerrarDetalle()
    {
        mostrarDetalle = false;
        moduloDetalle = null;
    }

    private void PaginaAnterior()
    {
        if (paginaActual > 1)
            paginaActual--;
    }

    private void PaginaSiguiente()
    {
        if (paginaActual < TotalPaginas)
            paginaActual++;
    }

    private void ReiniciarPaginacionSiHaceFalta()
    {
        if (paginaActual > TotalPaginas)
            paginaActual = TotalPaginas;
    }
}