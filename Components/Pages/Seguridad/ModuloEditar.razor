@page "/seguridad/modulos/editar/{id:int}"
@using ClinicaBlazor.Models
@inject ModuloService ModuloService
@inject NavigationManager Navigation

<PageTitle>Editar Módulo</PageTitle>

@if (modulo == null)
{
    <div class="loading-box">
        <p>⏳ Cargando módulo...</p>
    </div>
}
else
{
    <div class="form-container">

        <!-- HEADER -->
        <div class="form-header">
            <h2>✏️ Editar Módulo</h2>
            <p>Modifica la información del módulo</p>
        </div>

        <!-- FORM -->
        <EditForm Model="modulo" OnValidSubmit="Guardar" class="form-card">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label>Nombre</label>
                <input class="input-pro" @bind="modulo.Nombre" />
            </div>

            <div class="form-group">
                <label>Clave</label>
                <input class="input-pro" @bind="modulo.Clave" />
            </div>

            <div class="form-group">
                <label>Ruta</label>
                <input class="input-pro" @bind="modulo.Ruta" />
            </div>

            <!-- BOTONES -->
            <div class="form-actions">
                <button type="submit" class="btn-save">
                    💾 Actualizar
                </button>

                <button type="button" class="btn-cancel" @onclick="Volver">
                    ❌ Cancelar
                </button>
            </div>

        </EditForm>

    </div>
}

<style>

    /* 🌸 CONTENEDOR */
    .form-container {
        max-width: 600px;
        margin: auto;
        padding: 20px;
    }

    /* 🌸 HEADER */
    .form-header {
        background: linear-gradient(135deg, #ff4da6, #ff80bf);
        padding: 20px;
        border-radius: 15px;
        color: white;
        margin-bottom: 20px;
        box-shadow: 0 10px 25px rgba(255, 0, 128, 0.2);
    }

        .form-header h2 {
            margin: 0;
        }

    /* 🌸 CARD */
    .form-card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    /* 🌸 INPUT */
    .form-group {
        display: flex;
        flex-direction: column;
    }

        .form-group label {
            font-weight: bold;
            margin-bottom: 5px;
            color: #555;
        }

    .input-pro {
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #ffcce0;
        transition: 0.3s;
    }

        .input-pro:focus {
            outline: none;
            border-color: #ff4da6;
            box-shadow: 0 0 6px rgba(255, 0, 128, 0.3);
        }

    /* 🌸 BOTONES */
    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 10px;
    }

    .btn-save {
        background: linear-gradient(135deg, #ff4da6, #ff1a8c);
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 10px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-save:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(255, 0, 128, 0.3);
        }

    .btn-cancel {
        background: #ccc;
        border: none;
        padding: 10px 18px;
        border-radius: 10px;
        cursor: pointer;
    }

    /* 🌸 LOADING */
    .loading-box {
        text-align: center;
        margin-top: 50px;
        font-size: 18px;
        color: #888;
    }

</style>

@code {
    [Parameter] public int id { get; set; }
    Modulo? modulo;

    protected override async Task OnInitializedAsync()
    {
        modulo = await ModuloService.ObtenerPorIdAsync(id);
    }

    async Task Guardar()
    {
        await ModuloService.GuardarAsync(modulo!);
        Navigation.NavigateTo("/seguridad/modulos");
    }

    void Volver() => Navigation.NavigateTo("/seguridad/modulos");
}