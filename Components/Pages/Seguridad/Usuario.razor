@page "/seguridad/usuarios"
@rendermode InteractiveServer
@using ClinicaBlazor.Services
@inject UsuarioService UsuarioService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Usuarios</PageTitle>

<section class="module-header">
    <h1>Usuarios</h1>
    <p>Gestión de usuarios del sistema</p>

    <div class="header-actions">
        <input type="text"
               class="input-search"
               placeholder="Buscar usuario..."
               @bind="filtro"
               @bind:event="oninput" />

        <button class="btn-primary-custom"
                @onclick="IrNuevoUsuario">
            + Nuevo
        </button>
    </div>
</section>

<section class="card-table">
    <table class="custom-table">
        <thead>
            <tr>
                <th>Imagen</th>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Usuario</th>
                <th>Celular</th>
                <th>Perfil</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var u in usuariosFiltrados)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(u.Imagen))
                        {
                            <img src="@u.Imagen" class="user-img" />
                        }
                        else
                        {
                            <div class="img-placeholder">👤</div>
                        }
                    </td>

                    <td>@u.Nombre</td>
                    <td>@u.Correo</td>
                    <td>@u.Username</td>
                    <td>@u.NumeroCelular</td>
                    <td>@u.Perfil</td>

                    <td>
                        <span class="status @(u.Activo ? "activo" : "inactivo")">
                            @(u.Activo ? "Activo" : "Inactivo")
                        </span>
                    </td>

                    <!-- 🔥 ACCIONES -->
                    <td>
                        <div class="actions">

                            <!-- 👁 DETALLE -->
                            <button class="btn-action detail"
                                    @onclick="() => VerDetalle(u)">
                                👁
                            </button>

                            <!-- ✏ EDITAR -->
                            <button class="btn-action edit"
                                    @onclick="() => EditarUsuario(u.Id)">
                                ✏
                            </button>

                            <!-- 🗑 ELIMINAR -->
                            <button class="btn-action delete"
                                    @onclick="@(() => ConfirmarEliminar(u.Id))">
                                🗑
                            </button>

                        </div>
                    </td>
                </tr>
            }
        </tbody>
        <div class="pagination-pro">
            <button @onclick="Anterior" disabled="@(paginaActual == 1)">«</button>

            <span>Página @paginaActual de @totalPaginas</span>

            <button @onclick="Siguiente" disabled="@(paginaActual == totalPaginas)">»</button>
        </div>
    </table>
</section>

@code {
    private List<ClinicaBlazor.Models.Usuario> usuarios = new();
    private string filtro = "";
    private bool mostrarModalEliminar = false;
    private int usuarioAEliminarId;
    private int paginaActual = 1;
    private int registrosPorPagina = 5;

    private int totalPaginas =>
        (int)Math.Ceiling((double)usuarios.Count / registrosPorPagina);
   

    protected override async Task OnInitializedAsync()
    {
        usuarios = await UsuarioService.ObtenerUsuarios();
    }

    private List<ClinicaBlazor.Models.Usuario> usuariosFiltrados =>
        usuarios.Where(u =>
            string.IsNullOrWhiteSpace(filtro) ||
            (u.Nombre?.Contains(filtro, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (u.Username?.Contains(filtro, StringComparison.OrdinalIgnoreCase) ?? false)
        ).ToList();

    private void IrNuevoUsuario()
    {
        Navigation.NavigateTo("/seguridad/usuarios/nuevo");
    }
    private void EditarUsuario(int id)
    {
        Navigation.NavigateTo($"/seguridad/usuarios/editar/{id}");
    }

    private void VerDetalle(ClinicaBlazor.Models.Usuario u)
    {
        Navigation.NavigateTo($"/seguridad/usuarios/detalle/{u.Id}");
    }

    private void ConfirmarEliminar(int id)
    {
        usuarioAEliminarId = id;
        mostrarModalEliminar = true;
    }

    private async Task CargarUsuarios()
    {
        usuarios = await UsuarioService.ObtenerUsuarios();
    }

    private async Task EliminarConfirmado()
    {
        await UsuarioService.EliminarAsync(usuarioAEliminarId);

        mostrarModalEliminar = false;
        await CargarUsuarios();
    }
    void Anterior()
    {
        if (paginaActual > 1)
            paginaActual--;
    }

    void Siguiente()
    {
        if (paginaActual < totalPaginas)
            paginaActual++;
    }

    private void CancelarEliminar()
    {
        mostrarModalEliminar = false;
    }
}

@if (mostrarModalEliminar)
{
    <div class="modal-overlay">
        <div class="modal-box animate-fade">

            <h3>⚠️ Eliminar usuario</h3>
            <p>¿Estás seguro de eliminar este usuario?</p>

            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="CancelarEliminar">
                    Cancelar
                </button>

                <button class="btn btn-danger" @onclick="EliminarConfirmado">
                    Eliminar
                </button>
            </div>

        </div>
    </div>
}