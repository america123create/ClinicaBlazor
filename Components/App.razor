<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="ClinicaBlazor.styles.css" />
    <link rel="stylesheet" href="/app.css?v=5" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <script src="https://www.google.com/recaptcha/api.js?render=explicit" async defer></script>
    <script>
        window.renderLoginRecaptcha = (siteKey) => {
            const container = document.getElementById('login-recaptcha');
            if (!container) return;

            if (container.dataset.rendered === 'true') return;

            if (window.grecaptcha && typeof window.grecaptcha.render === 'function') {
                window.grecaptcha.render(container, {
                    sitekey: siteKey
                });
                container.dataset.rendered = 'true';
            }
        };

        window.getLoginRecaptchaToken = () => {
            const el = document.querySelector('[name="g-recaptcha-response"]');
            return el ? el.value : '';
        };
    </script>
    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)" />
</head>

<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script src="_framework/blazor.web.js"></script>
</body>

</html>