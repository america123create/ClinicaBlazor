@rendermode InteractiveServer
@using ClinicaBlazor.Services
@inject SesionService SesionService
@inject PerfilService PerfilService
@inject PermisoPerfilService PermisoPerfilService
@inject NavigationManager Navigation

<header class="topbar">
    <div class="topbar-inner">
        <div class="topbar-left">
            <a class="brand" href="/dashboard">
                <span class="brand-icon">🏥</span>
                ClinicaBlazor
            </a>

            @if (cargado && haySesion)
            {
                <nav class="topnav">
                    <a class="topnav-link @(EsRutaActiva("/dashboard") ? "active" : "")"
                       href="/dashboard">
                        🏠 Inicio
                    </a>

                    @if (TieneAlgunaRutaSeguridad())
                    {
                        <div class="topnav-dropdown">
                            <button type="button"
                                    class="topnav-link dropdown-toggle @(EsSeccionActiva("/seguridad") ? "active" : "")"
                                    @onclick='() => ToggleMenu("seguridad")'>
                                🔐 Seguridad <span class="arrow @(menuAbierto == "seguridad" ? "open" : "")">▾</span>
                            </button>

                            <div class="dropdown-menu @(menuAbierto == "seguridad" ? "show" : "")">
                                @if (rutasPermitidas.Contains("/seguridad/perfil"))
                                {
                                    <a class="dropdown-item" href="/seguridad/perfil" @onclick="CerrarMenus">
                                        <span class="item-icon">👤</span> Perfil
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/seguridad/modulos"))
                                {
                                    <a class="dropdown-item" href="/seguridad/modulos" @onclick="CerrarMenus">
                                        <span class="item-icon">📦</span> Módulos
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/seguridad/permisos-perfil"))
                                {
                                    <a class="dropdown-item" href="/seguridad/permisos-perfil" @onclick="CerrarMenus">
                                        <span class="item-icon">🔑</span> Permisos por Perfil
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/seguridad/usuarios"))
                                {
                                    <a class="dropdown-item" href="/seguridad/usuarios" @onclick="CerrarMenus">
                                        <span class="item-icon">👥</span> Usuarios
                                    </a>
                                }
                            </div>
                        </div>
                    }

                    @if (rutasPermitidas.Contains("/principal1") || rutasPermitidas.Contains("/principal1/uno") || rutasPermitidas.Contains("/principal1/dos"))
                    {
                        <div class="topnav-dropdown">
                            <button type="button"
                                    class="topnav-link dropdown-toggle @(EsSeccionActiva("/principal1") ? "active" : "")"
                                    @onclick='() => ToggleMenu("principal1")'>
                                Director 1 <span class="arrow @(menuAbierto == "principal1" ? "open" : "")">▾</span>
                            </button>

                            <div class="dropdown-menu @(menuAbierto == "principal1" ? "show" : "")">
                                @if (rutasPermitidas.Contains("/principal1"))
                                {
                                    <a class="dropdown-item" href="/principal1" @onclick="CerrarMenus">
                                        <span class="item-icon">📋</span> Principal 1
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/principal1/uno"))
                                {
                                    <a class="dropdown-item" href="/principal1/uno" @onclick="CerrarMenus">
                                        <span class="item-icon">▸</span> Principal 1.1
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/principal1/dos"))
                                {
                                    <a class="dropdown-item" href="/principal1/dos" @onclick="CerrarMenus">
                                        <span class="item-icon">▸</span> Principal 1.2
                                    </a>
                                }
                            </div>
                        </div>
                    }

                    @if (rutasPermitidas.Contains("/principal2") || rutasPermitidas.Contains("/principal2/uno") || rutasPermitidas.Contains("/principal2/dos"))
                    {
                        <div class="topnav-dropdown">
                            <button type="button"
                                    class="topnav-link dropdown-toggle @(EsSeccionActiva("/principal2") ? "active" : "")"
                                    @onclick='() => ToggleMenu("principal2")'>
                                Director 2 <span class="arrow @(menuAbierto == "principal2" ? "open" : "")">▾</span>
                            </button>

                            <div class="dropdown-menu @(menuAbierto == "principal2" ? "show" : "")">
                                @if (rutasPermitidas.Contains("/principal2"))
                                {
                                    <a class="dropdown-item" href="/principal2" @onclick="CerrarMenus">
                                        <span class="item-icon">📋</span> Principal 2
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/principal2/uno"))
                                {
                                    <a class="dropdown-item" href="/principal2/uno" @onclick="CerrarMenus">
                                        <span class="item-icon">▸</span> Principal 2.1
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/principal2/dos"))
                                {
                                    <a class="dropdown-item" href="/principal2/dos" @onclick="CerrarMenus">
                                        <span class="item-icon">▸</span> Principal 2.2
                                    </a>
                                }
                            </div>
                        </div>
                    }

                    @if (TieneAlgunaRutaModulos())
                    {
                        <div class="topnav-dropdown">
                            <button type="button"
                                    class="topnav-link dropdown-toggle"
                                    @onclick='() => ToggleMenu("modulos")'>
                                🗂 Módulos <span class="arrow @(menuAbierto == "modulos" ? "open" : "")">▾</span>
                            </button>

                            <div class="dropdown-menu @(menuAbierto == "modulos" ? "show" : "")">
                                <a class="dropdown-item" href="/dashboard" @onclick="CerrarMenus">
                                    <span class="item-icon">🏠</span> Salpicadero
                                </a>
                                <div class="dropdown-divider"></div>
                                @if (rutasPermitidas.Contains("/seguridad/perfil"))
                                {
                                    <a class="dropdown-item" href="/seguridad/perfil" @onclick="CerrarMenus">
                                        <span class="item-icon">👤</span> Perfiles
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/seguridad/usuarios"))
                                {
                                    <a class="dropdown-item" href="/seguridad/usuarios" @onclick="CerrarMenus">
                                        <span class="item-icon">👥</span> Usuarios
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/seguridad/modulos"))
                                {
                                    <a class="dropdown-item" href="/seguridad/modulos" @onclick="CerrarMenus">
                                        <span class="item-icon">📦</span> Módulos
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/seguridad/permisos-perfil"))
                                {
                                    <a class="dropdown-item" href="/seguridad/permisos-perfil" @onclick="CerrarMenus">
                                        <span class="item-icon">🔑</span> Permisos Perfil
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/principal1/uno") || rutasPermitidas.Contains("/principal1/dos"))
                                {
                                    <div class="dropdown-divider"></div>
                                }
                                @if (rutasPermitidas.Contains("/principal1/uno"))
                                {
                                    <a class="dropdown-item" href="/principal1/uno" @onclick="CerrarMenus">
                                        <span class="item-icon">▸</span> Principal 1.1
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/principal1/dos"))
                                {
                                    <a class="dropdown-item" href="/principal1/dos" @onclick="CerrarMenus">
                                        <span class="item-icon">▸</span> Principal 1.2
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/principal2/uno"))
                                {
                                    <a class="dropdown-item" href="/principal2/uno" @onclick="CerrarMenus">
                                        <span class="item-icon">▸</span> Principal 2.1
                                    </a>
                                }
                                @if (rutasPermitidas.Contains("/principal2/dos"))
                                {
                                    <a class="dropdown-item" href="/principal2/dos" @onclick="CerrarMenus">
                                        <span class="item-icon">▸</span> Principal 2.2
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </nav>
            }
        </div>

        <div class="topbar-right">
            @if (cargado && haySesion)
            {
                <div class="user-pill">
                    <div class="user-avatar">@(nombreUsuario?.Substring(0, 1).ToUpper() ?? "U")</div>
                    <div class="user-info">
                        <span class="user-greeting">Hola,</span>
                        <span class="user-name">@nombreUsuario</span>
                    </div>
                </div>

                <button class="logout-btn" @onclick="Salir">
                    <span>⏻</span> Cerrar Sesión
                </button>
            }
            else
            {
                <a class="login-link" href="/login">Iniciar sesión</a>
            }
        </div>
    </div>
</header>

@code {
    private bool haySesion;
    private bool cargado;
    private string? nombreUsuario;
    private string? perfilUsuario;
    private List<string> rutasPermitidas = new();
    private string? menuAbierto;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        haySesion = await SesionService.HaySesionAsync();
        nombreUsuario = await SesionService.ObtenerNombreAsync();
        perfilUsuario = await SesionService.ObtenerPerfilAsync();

        if (haySesion && !string.IsNullOrWhiteSpace(perfilUsuario))
        {
            var perfil = await PerfilService.ObtenerPorNombreAsync(perfilUsuario);

            if (perfil != null)
            {
                var permisos = await PermisoPerfilService.ObtenerPorPerfilIdAsync(perfil.Id);

                rutasPermitidas = permisos
                    .Where(p => p.Consultar && p.Modulo != null && !string.IsNullOrWhiteSpace(p.Modulo.Ruta))
                    .Select(p => p.Modulo!.Ruta!.Trim())
                    .Distinct()
                    .ToList();
            }
        }

        cargado = true;
        StateHasChanged();
    }

    private bool TieneAlgunaRutaSeguridad()
    {
        return rutasPermitidas.Contains("/seguridad/perfil")
            || rutasPermitidas.Contains("/seguridad/usuarios")
            || rutasPermitidas.Contains("/seguridad/modulos")
            || rutasPermitidas.Contains("/seguridad/permisos-perfil");
    }

    private bool TieneAlgunaRutaModulos()
    {
        return rutasPermitidas.Count > 0;
    }

    private void ToggleMenu(string nombreMenu)
    {
        menuAbierto = menuAbierto == nombreMenu ? null : nombreMenu;
    }

    private void CerrarMenus()
    {
        menuAbierto = null;
    }

    private bool EsRutaActiva(string ruta)
    {
        var actual = "/" + Navigation.ToBaseRelativePath(Navigation.Uri);
        return actual.Equals(ruta, StringComparison.OrdinalIgnoreCase);
    }

    private bool EsSeccionActiva(string prefijo)
    {
        var actual = "/" + Navigation.ToBaseRelativePath(Navigation.Uri);
        return actual.StartsWith(prefijo, StringComparison.OrdinalIgnoreCase);
    }

    private async Task Salir()
    {
        await SesionService.CerrarSesionAsync();
        Navigation.NavigateTo("/login", true);
    }
}
